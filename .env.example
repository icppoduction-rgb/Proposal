APP_DATA_HOST_PATH=/absolute/path/to/project/app-data
POSTGRES_DATA_HOST_PATH=/absolute/path/to/project/.docker/postgres
TZ=Asia/Tashkent

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cybersec_platform
POSTGRES_USER=cybersec
POSTGRES_PASSWORD=cybersec
DATABASE_URL=postgresql+asyncpg://cybersec:cybersec@postgres:5432/cybersec_platform
SYNC_DATABASE_URL=postgresql+psycopg://cybersec:cybersec@postgres:5432/cybersec_platform
STAGING_DATABASE_URL=postgresql+asyncpg://cybersec:cybersec@postgres:5432/cybersec_platform
STAGING_SYNC_DATABASE_URL=postgresql+psycopg://cybersec:cybersec@postgres:5432/cybersec_platform
NORMALIZED_DATABASE_URL=postgresql+asyncpg://cybersec:cybersec@postgres:5432/cybersec_platform
NORMALIZED_SYNC_DATABASE_URL=postgresql+psycopg://cybersec:cybersec@postgres:5432/cybersec_platform

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=cybersec
RABBITMQ_PASSWORD=cybersec
RABBITMQ_VHOST=cybersec
RABBITMQ_URL=amqp://cybersec:cybersec@rabbitmq:5672/cybersec
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://cybersec:cybersec@rabbitmq:5672/cybersec
CELERY_RESULT_BACKEND=redis://redis:6379/1
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_PUBLISH_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=10

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost
INFERENCE_SERVICE_URL=http://model-analiz:8001
LOG_SERVICE_URL=http://log-service:8002
DATA_PROCESSING_SERVICE_URL=http://data-processing-service:8003

DATA_ROOT=/app/app-data
RAW_DATA_PATH=/app/app-data/raw
ARCHIVE_DATA_PATH=/app/app-data/archives
PARSED_DATA_PATH=/app/app-data/parsed
NORMALIZED_DATA_PATH=/app/app-data/normalized
MODELS_PATH=/app/app-data/models
REPORTS_PATH=/app/app-data/reports
EXPLANATIONS_PATH=/app/app-data/explanations
LOGS_PATH=/app/app-data/logs
TMP_PATH=/app/app-data/tmp
LANGUAGE_EN_PATH=app-data/languages/en.json
LANGUAGE_RU_PATH=app-data/languages/ru.json

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123456
